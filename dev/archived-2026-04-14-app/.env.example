# Docker Compose Environment Variables
# Copy this file to .env and set secure values before running docker-compose up

# PostgreSQL credentials (REQUIRED — no defaults)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=sof_platform

# JWT signing key (REQUIRED — must be a long random string)
SECRET_KEY=generate-a-64-char-random-string-here

# Initial admin password (required on first boot to seed the admin user;
# must meet the password policy: 12+ chars, upper/lower/digit/special).
# If unset, admin seeding is skipped with a warning.
ADMIN_PASSWORD=set-a-strong-admin-password-here

# OpenAI API key (optional — only needed for AI features)
OPENAI_API_KEY=
