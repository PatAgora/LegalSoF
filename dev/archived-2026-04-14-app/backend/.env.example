# Environment
ENVIRONMENT=development
DEBUG=False

# Database — set your PostgreSQL credentials here
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

# Security — generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-a-strong-random-key>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# Initial admin account (used by scripts/init_db.py on first boot).
# ADMIN_PASSWORD is REQUIRED to create the admin user — if unset, admin
# seeding is skipped with a warning. Must meet the password policy:
# 12+ chars with upper, lower, digit, and special character.
# An existing admin user is never modified by the seeder.
ADMIN_EMAIL=admin@agora.ai
ADMIN_PASSWORD=<set-a-strong-admin-password>

# OpenAI (required for AI features)
OPENAI_API_KEY=

# AI extraction of Source of Funds claims from free-text client
# explanations. AI_PROVIDER selects the model provider: 'anthropic'
# (default) or 'gemini'. Set the matching API key. Leave the active
# provider's key blank to use the local keyword parser instead.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Feature Flags
ENABLE_AI_EXTRACTION=true
ENABLE_AI_NARRATIVE=true
