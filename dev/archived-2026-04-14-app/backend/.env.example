# Environment
ENVIRONMENT=development
DEBUG=True

# Database — set your PostgreSQL credentials here
DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASSWORD>@localhost:5432/<DB_NAME>

# Security — generate a strong random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=<generate-a-strong-random-key>
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# OpenAI (required for AI features)
OPENAI_API_KEY=

# Google Gemini — AI extraction of Source of Funds claims from
# free-text client explanations. Leave blank to use the local
# keyword parser instead. GEMINI_MODEL is optional.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8000"]

# Feature Flags
ENABLE_AI_EXTRACTION=true
ENABLE_AI_NARRATIVE=true
